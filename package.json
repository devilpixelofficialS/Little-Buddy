{
  "name": "little-buddy",
  "version": "0.1.0",
  "private": true,
  "main": "apps/desktop/electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:next": "cd apps/desktop/renderer && next dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev:skip-build": "concurrently \"npm run dev:next\" \"npm run dev:electron\"",
    "build": "npm run build:next && electron-builder",
    "build:next": "cd apps/desktop/renderer && next build",
    "build:electron": "tsc -p apps/desktop/electron/tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=100",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:push": "npx prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "next": "^16.2.9",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "wait-on": "^7.0.0"
  }
}
